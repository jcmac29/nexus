# Nexus Production Environment Configuration
# Copy to .env and update with secure values

# === Required Secrets ===
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secure-secret-key-min-32-chars
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars
STORAGE_SECRET_KEY=your-minio-secret-key

# === Database ===
DB_PASSWORD=your-secure-database-password

# === Storage ===
STORAGE_ACCESS_KEY=nexus

# === Optional: External Services ===
# Stripe (for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI (for advanced embeddings)
OPENAI_API_KEY=

# SendGrid (for email)
SENDGRID_API_KEY=

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
