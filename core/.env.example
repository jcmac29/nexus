# Nexus Configuration
# Copy this to .env and fill in your values

# === Core Settings ===
APP_NAME=Nexus
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development
API_PREFIX=/api/v1

# === Database ===
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Security ===
SECRET_KEY=change-me-in-production-use-a-real-secret-key

# === Storage (S3-compatible) ===
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=nexus
STORAGE_SECRET_KEY=nexus-secret-key
STORAGE_BUCKET=nexus-media
STORAGE_REGION=us-east-1

# === Embeddings ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# === OpenAI (for advanced embeddings) ===
OPENAI_API_KEY=

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# === Stripe (for billing) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === OAuth Providers ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Email (SendGrid) ===
SENDGRID_API_KEY=

# === SMS (Twilio) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === Secret Management ===
NEXUS_SECRET_BACKEND=env

# === Feature Flags ===
ENABLE_FEDERATION=true
ENABLE_MARKETPLACE=true
ENABLE_DEVICES=true

# === Infrastructure (for Worker Pools) ===
DIGITALOCEAN_TOKEN=
KUBERNETES_CONFIG_PATH=
NEXUS_PUBLIC_URL=https://api.nexus.ai
WORKER_IMAGE=nexus/worker:latest
DEFAULT_WORKER_REGION=nyc3
