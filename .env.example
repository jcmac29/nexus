# Nexus Configuration
# Copy to .env and fill in your values

# ===========================================
# REQUIRED - Must be set before running
# ===========================================

# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=nexus

# Redis
REDIS_PASSWORD=your-redis-password-here

# API Security
SECRET_KEY=your-secret-key-minimum-32-characters-long

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=your-minio-password-here

# ===========================================
# OPTIONAL - Production settings
# ===========================================

# Docker registry for production images
DOCKER_REGISTRY=your-registry.com/nexus
VERSION=latest

# Scaling
API_REPLICAS=3
WORKER_REPLICAS=2

# Multi-tenant mode
MULTI_TENANT_ENABLED=false
BASE_DOMAIN=nexus.your-domain.com

# Grafana
GRAFANA_PASSWORD=your-grafana-password
GRAFANA_ROOT_URL=https://grafana.your-domain.com

# ===========================================
# ADMIN DASHBOARD
# ===========================================

# JWT secret for admin sessions (separate from API secret)
ADMIN_JWT_SECRET=your-admin-jwt-secret-minimum-32-characters

# Session expiration in hours
ADMIN_TOKEN_EXPIRE_HOURS=24

# Initial admin user (created on first run if set)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Frontend URLs (for CORS configuration)
ADMIN_DASHBOARD_URL=https://admin.nexus.your-domain.com
LANDING_URL=https://nexus.your-domain.com

# ===========================================
# INTEGRATIONS - Enable as needed
# ===========================================

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-xxx

# ===========================================
# DEVELOPMENT - Local dev settings
# ===========================================

# Set to true for development
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=production
